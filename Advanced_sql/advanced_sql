/*practice problem*/
SELECT
    job_schedule_type,
    avg(salary_year_avg) AS yearly_avg,
    avg(salary_hour_avg) AS hourly_avg
FROM
    job_postings_fact
WHERE 
    job_posted_date::DATE > '2023-06-01'
GROUP BY
    job_schedule_type


SELECT
    COUNT(job_id) AS job_count,
    EXTRACT(MONTH FROM job_posted_date::DATE AT TIME ZONE 'UTC' AT TIME ZONE 'EST') AS month
FROM
    job_postings_fact
GROUP BY
   MONTH
order BY
    month DESC;



SELECT
    name,
    job_health_insurance,
    EXTRACT(MONTH FROM job_posted_date::DATE AT TIME ZONE 'UTC' AT TIME ZONE 'EST') AS month_date

FROM
    company_dim,
    job_postings_fact
   
WHERE
    EXTRACT(MONTH FROM job_posted_date::DATE AT TIME ZONE 'UTC' AT TIME ZONE 'EST') = 4 OR
    EXTRACT(MONTH FROM job_posted_date::DATE AT TIME ZONE 'UTC' AT TIME ZONE 'EST') = 5 OR
    EXTRACT(MONTH FROM job_posted_date::DATE AT TIME ZONE 'UTC' AT TIME ZONE 'EST') = 6 AND
    job_health_insurance = TRUE


LIMIT
    100000;

-- case practice problem
SELECT 
    salary_year_avg
    
FROM 
    job_postings_fact
LIMIT
    1000;


-- case exercise
SELECT 
    *,
    CASE
        WHEN salary_year_avg > 0 AND salary_year_avg < 50000 THEN 'Low'
        WHEN salary_year_avg > 50000 AND salary_year_avg < 100000 THEN 'Standard'
        WHEN salary_year_avg > 100000 THEN 'High'
    ELSE NULL
    END
FROM
    job_postings_fact
WHERE
    job_title_short = 'Data Analyst'
ORDER BY 
    salary_year_avg DESC;
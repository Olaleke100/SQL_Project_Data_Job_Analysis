-- union practice problem
WITH temp_post AS (
SELECT
    skills,
    type,
    job_id
FROM
    skills_dim
RIGHT JOIN skills_job_dim ON skills_dim.skill_id  = skills_job_dim.skill_id
WHERE job_id IN (
        SELECT
            job_id
        FROM
            january_jobs
        UNION ALL
        SELECT
            job_id
        FROM
            febuary_jobs
        UNION ALL
        SELECT
            job_id
        FROM
            march_jobs
    )
)

SELECT
    skills,
    type,
    salary_year_avg AS yearly_avg,
    EXTRACT(MONTH FROM job_posted_date) AS posted_month
FROM
    job_postings_fact
LEFT JOIN temp_post ON job_postings_fact.job_id = temp_post.job_id
WHERE 
    salary_year_avg > 70000

-- union practice problem end


--practice problem 8
SELECT 
    quarter1.job_title_short,
    quarter1.job_location,
    quarter1.job_via,
    quarter1.job_posted_date::DATE,
    quarter1.salary_year_avg
FROM (
    SELECT *
    FROM january_jobs
    UNION ALL
    SELECT *
    FROM febuary_jobs
    UNION ALL
    SELECT *
    FROM march_jobs
) AS quarter1
WHERE
    quarter1.salary_year_avg > 70000 AND
    quarter1.job_title_short = 'Data Analyst'
ORDER BY
    quarter1.salary_year_avg DESC

